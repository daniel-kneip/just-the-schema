{
  "name": "just-the-schema",
  "version": "0.1.0",
  "description": "TypeSpec emitter that emits Zod schemas",
  "keywords": [
    "typespec",
    "typespec-emitter",
    "zod",
    "codegen",
    "schema",
    "validation"
  ],
  "license": "MIT",
  "author": "Daniel Kneip",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/daniel-kneip/just-the-schema.git"
  },
  "homepage": "https://github.com/daniel-kneip/just-the-schema#readme",
  "bugs": "https://github.com/daniel-kneip/just-the-schema/issues",
  "type": "module",
  "main": "dist/index.js",
  "exports": {
    ".": {
      "typespec": "./lib/main.tsp",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "lib"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "sample": "tsp compile sample",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "knip": "knip",
    "check:package": "publint && attw --pack . --ignore-rules cjs-resolves-to-esm",
    "check": "pnpm lint && pnpm format:check && pnpm knip && pnpm test:coverage",
    "prepack": "tsc -p tsconfig.build.json"
  },
  "peerDependencies": {
    "@typespec/compiler": ">=1.0.0",
    "zod": ">=4.0.0"
  },
  "devDependencies": {
    "@typespec/compiler": "1.13.0",
    "typescript": "5.9.3",
    "@arethetypeswrong/cli": "0.18.3",
    "@eslint/js": "10.0.1",
    "@vitest/coverage-v8": "4.1.9",
    "eslint": "10.5.0",
    "eslint-config-prettier": "10.1.8",
    "knip": "6.17.1",
    "prettier": "3.8.4",
    "publint": "0.3.21",
    "typescript-eslint": "8.61.1",
    "vitest": "4.1.9",
    "zod": "4.4.3"
  },
  "packageManager": "pnpm@11.8.0"
}
